# ── AcademIQ backend configuration ───────────────────────────────────────────
# Copy this file to `.env` and fill in real values. All variables are optional;
# anything left unset falls back to the defaults in app/config/settings.py.

# --- Database ---------------------------------------------------------------
# Defaults to the existing Atlas cluster if unset.
MONGODB_URI= mongodb+srv://khaledhsbllah_db_user:khaledmiupassword@cluster0.hcvs2st.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=todo_db

# --- CORS -------------------------------------------------------------------
# Comma-separated origins allowed to call the API with credentials (cookies).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Sessions ---------------------------------------------------------------
SESSION_COOKIE_NAME=academiq_session
SESSION_TTL_HOURS=24
# Set to true when serving over HTTPS in production.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# --- Frontend / email -------------------------------------------------------
APP_LOGIN_URL=http://localhost:3000/signin

# SMTP — leave blank to log account-creation emails to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=x
SMTP_FROM=AcademIQ <no-reply@academiq.local>
SMTP_USE_TLS=true

# --- Initial admin (used by `python -m app.scripts.seed_admin`) -------------
ADMIN_EMAIL=admin@academiq.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=AcademIQ Admin
