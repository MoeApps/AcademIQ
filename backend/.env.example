# ── AcademIQ backend configuration ───────────────────────────────────────────
# Copy this file to `.env` and fill in real values.

# --- Database ---------------------------------------------------------------
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
DATABASE_NAME=todo_db
# MONGODB_DB_NAME is still accepted as an alias for DATABASE_NAME

# --- JWT (development defaults — change JWT_SECRET_KEY in production) -------
JWT_SECRET_KEY=DEV-ONLY-change-me-in-production-academiq-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS (local dev) -------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://localhost:5173,http://localhost:8080

# --- CORS (production — set in Hugging Face Space secrets) -----------------
# ALLOWED_ORIGINS=https://your-app.vercel.app
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=none
# APP_LOGIN_URL=https://your-app.vercel.app/signin
# BOOTSTRAP_ADMIN=true

# --- Sessions ---------------------------------------------------------------
SESSION_COOKIE_NAME=academiq_session
SESSION_TTL_HOURS=24
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# --- Frontend / email -------------------------------------------------------
APP_LOGIN_URL=http://localhost:3000/signin

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AcademIQ <no-reply@academiq.local>
SMTP_USE_TLS=true

# --- Initial admin (used by `python -m app.scripts.seed_admin`) -------------
ADMIN_EMAIL=admin@academiq.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=AcademIQ Admin
