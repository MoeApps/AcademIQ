# ── AcademIQ backend — copy to `.env` for local development ─────────────────
# On Render, set these in the service Environment dashboard (never commit .env).

# --- Required (production) --------------------------------------------------
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
DATABASE_NAME=todo_db

# DEV-ONLY default below — generate a strong random secret for production.
JWT_SECRET_KEY=DEV-ONLY-change-me-in-production-academiq-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated frontend origins (include your Vercel URL in production).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Environment ------------------------------------------------------------
# development = local defaults allowed | production = strict env validation
ENVIRONMENT=development

# --- Optional bootstrap (idempotent — safe to re-run) ----------------------
# BOOTSTRAP_STUDENTS=true
# BOOTSTRAP_ADMIN=true

# --- Legacy session routes (admin / extension) ------------------------------
SESSION_COOKIE_NAME=academiq_session
SESSION_TTL_HOURS=24
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# --- Frontend / email -------------------------------------------------------
APP_LOGIN_URL=http://localhost:3000/signin

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AcademIQ <no-reply@academiq.local>
SMTP_USE_TLS=true

# --- Initial admin (used by `python -m app.scripts.seed_admin`) -------------
ADMIN_EMAIL=admin@academiq.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=AcademIQ Admin
