# Copy to .env in the project root (AcademIQ-main) and adjust values.

# --- MongoDB ---
# Local (install MongoDB Community or use Docker: docker run -d -p 27017:27017 mongo:7)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=todo_db

# Or MongoDB Atlas (replace with your connection string from Atlas UI):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=AcademIQ

# --- API ---
# DEBUG=true
# RISK_MODEL_PATH=backend/models/risk_model.pkl

# --- AI study (quiz / notes) — optional; without a key, offline templates are used ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# AI_QUIZ_NUM_QUESTIONS=4

# Comma-separated origins (React/Vite dev servers, Swagger, etc.)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Allow any Chrome extension origin for popup → API (set empty to disable)
CORS_ORIGIN_REGEX=chrome-extension://.*
