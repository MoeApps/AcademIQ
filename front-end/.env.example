# Copy this file to .env.local and adjust as needed.
#
# When NEXT_PUBLIC_API_BASE_URL is empty (or the file is missing entirely),
# the frontend runs in mock-data mode — no backend required.

# Point at your running FastAPI backend to use real data:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Force mock mode even when the backend URL is set (rarely needed):
# NEXT_PUBLIC_USE_MOCK=true
